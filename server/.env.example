PORT=4000
DATABASE_URL=postgresql://user:password@localhost:5432/ticket_management
BETTER_AUTH_SECRET=your-secret-here
BETTER_AUTH_URL=http://localhost:4000
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# Base URL of the backend used by Playwright e2e tests
TEST_BACKEND_URL=http://localhost:5001

# Webhook secret — guards POST /api/webhooks/*
# Leave blank to disable auth (dev/test); REQUIRED in production
WEBHOOK_SECRET=

# Kimi (Moonshot) AI API key — required for polish, summarize, classify, auto-resolve
# Obtain from https://platform.moonshot.ai
MOONSHOT_API_KEY=

# Sentry — server-side error monitoring
# Obtain from https://sentry.io
SENTRY_DSN=

# Gmail SMTP — outbound reply emails (sent when agent posts a comment on an email ticket)
# Requires 2FA on the Google account, then generate an App Password at:
# https://myaccount.google.com/apppasswords
# Leave blank to disable outbound emails (server will warn but continue)
GMAIL_USER=support@gmail.com
GMAIL_APP_PASSWORD=

# Seed Admin User — used by prisma/seed.ts only
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-password-here

# Gmail API — inbound email via Google Pub/Sub push
# Full setup guide:
# 1. Create a GCP project and enable Gmail API + Cloud Pub/Sub API
# 2. Create a Pub/Sub topic (e.g. gmail-push) and a push subscription pointing to:
#    https://your-domain/api/webhooks/gmail
# 3. Grant publish rights: gcloud pubsub topics add-iam-policy-binding gmail-push \
#    --member="serviceAccount:gmail-api-push@system.gserviceaccount.com" --role="roles/pubsub.publisher"
# 4. Create OAuth2 credentials (Desktop app) in GCP console
# 5. Run: cd server && bun run scripts/gmail-auth.ts  — to obtain GOOGLE_REFRESH_TOKEN
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GMAIL_PUBSUB_TOPIC=projects/YOUR_PROJECT_ID/topics/gmail-push
GMAIL_PUBSUB_SECRET=
