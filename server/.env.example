PORT=4000
DATABASE_URL=postgresql://user:password@localhost:5432/ticket_management
BETTER_AUTH_SECRET=your-secret-here
BETTER_AUTH_URL=http://localhost:4000
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# Base URL of the backend used by Playwright e2e tests
TEST_BACKEND_URL=http://localhost:5001

# Webhook secret — guards POST /api/webhooks/*
# Leave blank to disable auth (dev/test); REQUIRED in production
WEBHOOK_SECRET=

# Kimi (Moonshot) AI API key — required for polish, summarize, classify, auto-resolve
# Obtain from https://platform.moonshot.ai
MOONSHOT_API_KEY=

# Sentry — server-side error monitoring
# Obtain from https://sentry.io
SENTRY_DSN=

# CloudMailin — outbound reply emails (sent when agent posts a comment on an email ticket)
# Obtain SMTP credentials from your CloudMailin account dashboard
# Leave all blank to disable outbound emails (server will warn but continue)
CLOUDMAILIN_SMTP_HOST=
CLOUDMAILIN_SMTP_PORT=587
CLOUDMAILIN_SMTP_USER=
CLOUDMAILIN_SMTP_PASS=
CLOUDMAILIN_FROM_EMAIL=

# Seed Admin User — used by prisma/seed.ts only
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-password-here
